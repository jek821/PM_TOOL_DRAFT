# Copy this file to .env.local and fill in the values. Do not commit .env.local.

# The Anthropic API key is used SERVER-SIDE ONLY (in Next.js API routes) and is
# never exposed to the browser. Without it the app falls back to its sample tier
# and still runs end to end.
ANTHROPIC_API_KEY=

# Demo login. /api/login verifies these server-side, then sets an httpOnly cookie
# holding AUTH_SECRET, which middleware.ts checks on every request.
#
# NOTE: the auth gate is DISABLED unless all three are set — convenient for local
# dev, but it means the deployment is open to anyone if they are missing. Set all
# three in the hosting environment.
DEMO_USER=
DEMO_PASSWORD=

# Any random string. This is the value stored in the session cookie — it is the
# session secret, so use something long and don't reuse it elsewhere.
AUTH_SECRET=
